fn swap(mut arr: number[], i: number, j: number) -> number {
  let tmp = arr[i];
  arr[i] = arr[j];
  arr[j] = tmp;
  return 0;
}

fn bubble_sort(mut arr: number[]) -> number {
  let n = arr.len();
  let mut i = 0;
  while i < n {
    let mut j = 0;
    while j < n - i - 1 {
      if arr[j] > arr[j + 1] {
        swap(arr, j, j + 1);
      }
      j += 1;
    }
    i += 1;
  }
  return n;
}

let mut xs = [5, 2, 9, 1, 7, 3, 8, 4, 6, 0];
bubble_sort(xs);
for v in xs {
  print(v);
}

let mut empty = [] as number[];
bubble_sort(empty);
print(empty.len());

let mut one = [42];
bubble_sort(one);
print(one[0]);

let mut dups = [3, 1, 2, 1, 3, 2, 1];
bubble_sort(dups);
for v in dups {
  print(v);
}
