fn merge(mut arr: number[], mut aux: number[], lo: number, mid: number, hi: number) -> number {
  let mut k = lo;
  while k <= hi {
    aux[k] = arr[k];
    k += 1;
  }

  let mut i = lo;
  let mut j = mid + 1;
  k = lo;
  while k <= hi {
    if i > mid {
      arr[k] = aux[j];
      j += 1;
    } else {
      if j > hi {
        arr[k] = aux[i];
        i += 1;
      } else {
        if aux[j] < aux[i] {
          arr[k] = aux[j];
          j += 1;
        } else {
          arr[k] = aux[i];
          i += 1;
        }
      }
    }
    k += 1;
  }
  return 0;
}

fn mergesort(mut arr: number[], mut aux: number[], lo: number, hi: number) -> number {
  if lo < hi {
    let mid = (lo + hi) / 2;
    mergesort(arr, aux, lo, mid);
    mergesort(arr, aux, mid + 1, hi);
    merge(arr, aux, lo, mid, hi);
  }
  return 0;
}

fn sort(mut arr: number[]) -> number {
  let n = arr.size();
  let mut aux = [] as number[];
  let mut t = 0;
  while t < n {
    aux.push(0);
    t += 1;
  }
  if n > 1 {
    mergesort(arr, aux, 0, n - 1);
  }
  return n;
}

let mut xs = [38, 27, 43, 3, 9, 82, 10];
sort(xs);
for v in xs {
  print(v);
}

let mut nums = [5, 1, 4, 2, 8, 7, 3, 6, 9, 0];
sort(nums);
for v in nums {
  print(v);
}

let mut mixed = [0, -5, 10, -20, 15, 3, -1];
sort(mixed);
for v in mixed {
  print(v);
}

let mut tiny = [2, 1];
sort(tiny);
print(tiny[0]);
print(tiny[1]);
