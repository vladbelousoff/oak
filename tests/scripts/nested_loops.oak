let mut total = 0;
for i from 0 to 5 {
  for j from 0 to 5 {
    total += 1;
  }
}
print(total);

let mut product_sum = 0;
for i from 1 to 4 {
  for j from 1 to 4 {
    product_sum += i * j;
  }
}
print(product_sum);

let mut found = 0;
for i from 0 to 10 {
  for j from 0 to 10 {
    if i * j == 42 {
      found = 1;
      break;
    }
  }
  if found == 1 {
    break;
  }
}
print(found);
