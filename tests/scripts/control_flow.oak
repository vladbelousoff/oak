let x = 10;

if x == 10 {
  print(1);
}

if x != 10 {
  print(0);
} else {
  print(2);
}

if x > 5 {
  print(3);
}

if x < 5 {
  print(0);
} else {
  print(4);
}

if x >= 10 {
  print(5);
}

if x <= 10 {
  print(6);
}

let mut a = 1;
if a == 1 {
  if x > 0 {
    print(7);
  }
}

let y = 0;
if !y {
  print(8);
}
